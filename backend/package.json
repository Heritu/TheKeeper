{
  "name": "the-keeper-backend",
  "version": "0.1.0",
  "private": true,
  "description": "API Express em TypeScript para o The Keeper.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "express": "^5.2.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.4",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3"
  }
}
